# =============================================================================
# ChartChemistry Environment Variables
# =============================================================================
# Copy this file to .env and fill in the values

# -----------------------------------------------------------------------------
# Database (PostgreSQL)
# -----------------------------------------------------------------------------
DATABASE_URL="postgresql://user:password@localhost:5432/chartchemistry?schema=public"

# -----------------------------------------------------------------------------
# NextAuth
# -----------------------------------------------------------------------------
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="generate-a-secure-secret-with-openssl-rand-base64-32"

# -----------------------------------------------------------------------------
# Google OAuth
# -----------------------------------------------------------------------------
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# -----------------------------------------------------------------------------
# Email Provider (Magic Link)
# -----------------------------------------------------------------------------
EMAIL_SERVER_HOST="smtp.example.com"
EMAIL_SERVER_PORT=587
EMAIL_SERVER_USER=""
EMAIL_SERVER_PASSWORD=""
EMAIL_FROM="noreply@chartchemistry.com"

# -----------------------------------------------------------------------------
# Anthropic (Claude API)
# -----------------------------------------------------------------------------
ANTHROPIC_API_KEY=""

# -----------------------------------------------------------------------------
# Stripe
# -----------------------------------------------------------------------------
STRIPE_SECRET_KEY=""
STRIPE_PUBLISHABLE_KEY=""
STRIPE_WEBHOOK_SECRET=""
STRIPE_PREMIUM_PRICE_ID=""
STRIPE_ANNUAL_PRICE_ID=""

# -----------------------------------------------------------------------------
# Cron Jobs
# -----------------------------------------------------------------------------
CRON_SECRET="your-secure-cron-secret-here"

# -----------------------------------------------------------------------------
# Astrology Microservice
# -----------------------------------------------------------------------------
ASTRO_SERVICE_URL="http://localhost:8000"
