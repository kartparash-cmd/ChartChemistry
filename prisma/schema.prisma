generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id               String    @id @default(cuid())
  email            String    @unique
  name             String?
  image            String?
  password         String?
  emailVerified    DateTime?
  plan             Plan      @default(FREE)
  role             Role      @default(USER)
  stripeCustomerId String?
  streakCount      Int       @default(0)
  lastCheckinDate  DateTime?
  referralCode     String?   @unique
  referredBy       String?
  referralCount    Int       @default(0)
  referralRewardClaimed Boolean @default(false)
  emailDigest      Boolean   @default(true)
  emailMarketing   Boolean   @default(false)
  pushEnabled      Boolean   @default(false)
  pushSubscription Json?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  accounts       Account[]
  sessions       Session[]
  birthProfiles  BirthProfile[]
  reports        CompatibilityReport[]
  chatSessions   ChatSession[]
  supportTickets SupportTicket[]
  ticketReplies  TicketReply[]
  achievements   UserAchievement[]
  marieMemories  MarieMemory[]
  relationshipCheckIns RelationshipCheckIn[]

  @@index([stripeCustomerId])
}

enum Role {
  USER
  ADMIN
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  email     String
  token     String   @unique
  expires   DateTime
  createdAt DateTime @default(now())

  @@unique([email, token])
}

enum Plan {
  FREE
  PREMIUM
  ANNUAL
}

model BirthProfile {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name         String
  birthDate    DateTime
  birthTime    String?
  birthCity    String
  birthCountry String
  latitude     Float
  longitude    Float
  timezone     String
  isOwner      Boolean  @default(false)
  isPublic     Boolean  @default(false)
  chartData    Json?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  reportsAsPerson1 CompatibilityReport[] @relation("Person1")
  reportsAsPerson2 CompatibilityReport[] @relation("Person2")

  @@index([userId])
}

model CompatibilityReport {
  id       String @id @default(cuid())
  userId   String
  user     User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  person1Id String
  person1   BirthProfile @relation("Person1", fields: [person1Id], references: [id])
  person2Id String
  person2   BirthProfile @relation("Person2", fields: [person2Id], references: [id])

  overallScore       Int
  communicationScore Int
  emotionalScore     Int
  chemistryScore     Int
  stabilityScore     Int
  conflictScore      Int

  summaryNarrative String @db.Text
  fullNarrative    String @db.Text
  redFlags         Json
  growthAreas      Json

  synastryData  Json
  compositeData Json?

  shareToken       String? @unique
  sharedWithUserId String?

  tier      ReportTier @default(FREE)
  createdAt DateTime   @default(now())

  @@unique([person1Id, person2Id])
  @@index([userId])
}

enum ReportTier {
  FREE
  PREMIUM
  BOUTIQUE
}

model ChatSession {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  reportId  String?
  title     String?
  pinned    Boolean   @default(false)
  archived  Boolean   @default(false)
  deletedAt DateTime?
  messages  Json
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([userId])
  @@index([userId, deletedAt])
}

enum TicketStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}

model SupportTicket {
  id          String       @id @default(cuid())
  userId      String
  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  subject     String
  description String       @db.Text
  status      TicketStatus @default(OPEN)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  replies TicketReply[]

  @@index([userId])
}

model TicketReply {
  id        String   @id @default(cuid())
  ticketId  String
  ticket    SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  message   String   @db.Text
  isAdmin   Boolean  @default(false)
  createdAt DateTime @default(now())
}

model MarieMemory {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  key       String   // e.g. "user_name", "partner_name", "relationship_concern", "communication_style"
  value     String   @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, key])
  @@index([userId])
}

model UserAchievement {
  id              String   @id @default(cuid())
  userId          String
  achievementType String
  unlockedAt      DateTime @default(now())
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, achievementType])
  @@index([userId])
}

model RelationshipCheckIn {
  id              String   @id @default(cuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  connectionScore Int      // 1-5
  conflictNote    String?  @db.Text
  positiveNote    String?  @db.Text
  growthGoal      String?  @db.Text
  overallMood     String   // e.g. "hopeful", "stressed", "connected", "distant"
  createdAt       DateTime @default(now())

  @@index([userId])
  @@index([userId, createdAt])
}

model EmailSubscriber {
  id        String   @id @default(cuid())
  email     String   @unique
  sign      String?  // zodiac sign preference
  source    String   @default("exit_popup") // "exit_popup", "inline_capture"
  createdAt DateTime @default(now())

  @@index([createdAt])
}

model MarieAnalytics {
  id            String   @id @default(cuid())
  topic         String   // e.g. "relationship", "chart_education", "timing", "conflict", "general"
  sentiment     String   // "positive", "neutral", "negative"
  questionType  String   // "how", "why", "what", "explain", "advice", "checkin"
  hasReport     Boolean  // whether user had a report loaded
  hasMemories   Boolean  // whether user had existing memories
  messageLength Int      // user message char count
  responseLength Int     // AI response char count
  dayOfWeek     Int      // 0-6
  hourOfDay     Int      // 0-23
  createdAt     DateTime @default(now())

  @@index([topic])
  @@index([createdAt])
}
